# Example environment variables for pi-calendar-display.
# Copy this file to .env and fill in the values (.env is gitignored).
# Values in .env take precedence over config.json. Keep secrets here.
# Note: inline comments (KEY=value # ...) are NOT supported.

# --- Google OAuth (calendar access; issue in the Google Cloud Console) ---
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Defaults to http://localhost:<PORT>/oauth2callback if unset.
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# --- Calendars to display (JSON array string; overrides `calendars` in config.json) ---
# Example: a main calendar + a work-location calendar
# CALENDARS=[{"id":"primary","label":"Main","role":"events"},{"id":"xxxx@group.calendar.google.com","label":"Work location","role":"location"}]

# --- Weather (Open-Meteo; coordinates and timezone) ---
WEATHER_LATITUDE=35.6895
WEATHER_LONGITUDE=139.6917
WEATHER_LOCATION_NAME=Tokyo
WEATHER_TIMEZONE=Asia/Tokyo

# --- Stocks (Yahoo Finance; powers the /portrait ticker) ---
# No API key needed. Configure symbols in config.json under "stocks".
# Set "stocks.enabled": false there to disable the ticker.

# --- Server ---
PORT=3000
